FRONTEND_PORT=18080
TEXTMSA_API_PORT=18000
SYSTEM_SERVER_PORT=19000
MONGO_PORT=27018

# Core deployment keeps analysis services stopped by default.
# Set AUTO_START_SERVICES=true to let system_server start services at boot.
AUTO_START_SERVICES=false
SERVICE_RUN_MODE=process
STOP_SERVICES_ON_SHUTDOWN=false
DOCKER_BUILD_ON_START=false
