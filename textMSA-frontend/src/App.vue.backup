          </router-link> -->
        </nav>
      </div>
      <div class="status-bar-right">
        <!-- 语言切换下拉框 -->
        <div class="language-switcher">
          <select 
            :value="currentLocale" 
            @change="changeLocale(($event.target as HTMLSelectElement).value)"
            class="lang-select"
          >
            <option value="zh-CN">{{ $t('app.languageChinese') }}</option>
            <option value="en-US">{{ $t('app.languageEnglish') }}</option>
          </select>
        </div>
      </div>
    </div>
    
    <!-- 主内容区域：路由视图 -->
    <div class="app-container">
      <router-view />
    </div>
    
    <!-- 消息提示组件 -->
    <MessageToast />
    
    <!-- Token 认证弹窗 -->
    <TokenAuthDialog
      v-model="authStore.showTokenDialog"
      @confirm="handleTokenConfirm"
    />
  </div>
</template>

<script setup lang="ts">
import { computed, watch, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { useI18n } from 'vue-i18n'
import MessageToast from './components/common/MessageToast.vue'
import Icon from './components/common/Icon.vue'
import TokenAuthDialog from './components/auth/TokenAuthDialog.vue'
import { useUserStore } from './stores/userStore'
import { useAuthStore } from './stores/authStore'

const router = useRouter()
const { locale } = useI18n()
const currentLocale = computed(() => locale.value)
const userStore = useUserStore()
const authStore = useAuthStore()

// 检查当前路由是否为Service相关页面（包括创建和编辑）
const isServiceRoute = computed(() => {
  const path = router.currentRoute.value.path
  return path === '/services' || path.startsWith('/services/')
})

/**
 * 切换语言
 */
function changeLocale(lang: string) {
  locale.value = lang
  localStorage.setItem('app_locale', lang)
}

/**
 * 检查路由并验证 token
 */
function checkRouteAuth() {
  const currentPath = router.currentRoute.value.path
  
  // HelpPage 不需要 token
  if (currentPath === '/help') {
    return
  }
  
  // 检查是否有 token
  if (!authStore.checkAuth()) {
    // 没有 token，显示认证弹窗
    authStore.showAuthDialog()
  } else {
    // 有 token，确保用户信息已加载
    if (!userStore.profile) {
      userStore.fetchProfile().catch(err => {
        console.warn('获取用户信息失败:', err)
      })
    }
  }
}

/**
 * Token 确认后的处理
 */
async function handleTokenConfirm(_token: string) {
  try {
    // 获取用户信息
    await userStore.fetchProfile()
  } catch (error) {
    console.warn('获取用户信息失败:', error)
  }
}

/**
 * 监听路由变化，检查 token
 */
watch(
  () => router.currentRoute.value.path,
  (newPath) => {
    // HelpPage 不需要 token 校验，直接跳过
    if (newPath === '/help') {
      return
    }
    checkRouteAuth()
  },
  { immediate: false }
)

/**
 * 应用启动时检查认证状态
 */
onMounted(() => {
  // HelpPage 不需要 token 校验，直接跳过
  if (router.currentRoute.value.path === '/help') {
    return
  }
  checkRouteAuth()
})
</script>

