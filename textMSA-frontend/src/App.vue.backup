          </router-link>
          <router-link 
            to="/help" 
            class="nav-item"
            :class="{ active: $route.path === '/help' }"
          >
            <Icon name="help" size="md" class="nav-icon" />
            <span class="nav-label">{{ $t('navigation.help') }}</span>
          </router-link>
          <!-- <router-link 
            to="/spatial-coexpression" 
            class="nav-item"
            :class="{ active: $route.path === '/spatial-coexpression' }"
          >
            <Icon name="graph" size="md" class="nav-icon" />
