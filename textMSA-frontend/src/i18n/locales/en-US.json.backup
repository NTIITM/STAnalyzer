  "help": {
    "title": "Help Documentation",
    "introduction": {
      "title": "STA-MAS User Guide",
      "whatIs": {
        "title": "What is STA-MAS?",
        "description": "**STA-MAS (Spatial Transcriptomics Analyzer by Multi-agent Analysis System)** is a multi-agent automatic analysis system for spatial transcriptomics and text tasks. It integrates project management, data management, visualization analysis, and intelligent Agent dialogue in the same workspace, helping users complete the entire workflow from data upload to analysis result viewing."
      },
      "coreFeatures": {
        "title": "Core Features:",
        "items": [
          "**Project & Data Management**: Organize files, execution records, and results by project, supporting parallel management of multiple projects",
          "**Execution DAG Visualization**: Automatically generate and display execution graphs (DAG), showing files, execution steps, and their dependencies",
          "**Multi-perspective Data Analysis**: Support file perspective, execution perspective, and visualization analysis for specific data types",
          "**Intelligent Agent Dialogue**: Interact with Agent through natural language, automatically generate analysis plans, execute services, and explain results",
          "**Service Management**: Provide service information queries and relationship graphs to help understand the support relationships between services and file types"
        ]
      },
      "advantages": {
        "title": "Main Advantages:",
        "items": [
          "**Lower Usage Threshold**: Unified interface design simplifies complex analysis workflows",
          "**Improve Reproducibility**: Complete recording of analysis processes through DAG and execution management, facilitating traceability and reproduction",
          "**Enhance Interpretability**: Combine visualization display and Agent text explanations to help understand analysis results"
        ]
      },
      "frameworkImage": "STA-MAS System Architecture Diagram"
    },
    "sections": {
      "gettingStarted": {
        "title": "Getting Started",
        "description": "Completing a complete analysis workflow with STA-MAS typically includes the following steps:",
        "steps": {
          "createProject": {
            "title": "1. Create a Project",
            "description": "Projects are the basic unit for organizing analysis data and execution records. Each project has its own file list, DAG view, and Agent conversation context.",
            "steps": [
              "In the left project list on the Analysis page, click the \"New Project\" button",
              "Enter a project name in the popup dialog (recommended to use meaningful names, such as \"Spatial Transcriptomics Analysis_2024\")",
              "Click the \"Save\" button in the top-right corner to save the project"
            ],
            "purpose": {
              "title": "Purpose of Projects:",
              "items": [
                "Each project has its own file list, DAG execution graph, and Agent conversation context.",
                "Supports parallel management of multiple projects, facilitating simultaneous work on multiple different analysis tasks.",
                "Project data is persistently saved, allowing you to continue previous analysis work after logging in again."
              ]
            },
            "tip": "Project data is persistently saved, supporting parallel management of multiple projects, facilitating simultaneous work on multiple different analysis tasks.",
            "image": "Create Project Interface"
          },
          "uploadData": {
            "title": "2. Upload Data",
            "description": "Uploading data files is a prerequisite for analysis. The system supports multiple file formats, including spatial transcriptomics data, text files, configuration files, etc.",
            "steps": [
              "**Select Project**: Ensure the target project is selected (highlighted in the left project list)",
              "**Open Upload Dialog**: Click the \"Add Data\" or \"Upload File\" button in the left file list panel",
              "**Fill File Information**:",
              "  - **Select Local File**: Click the \"Select File\" button to choose a file from your local file system.",
              "  - **Enter Data Name**: Give the file an easily identifiable name (required).",
              "  - **Add Description** (optional but recommended): Fill in detailed file description, such as data source, experimental conditions, key parameters, etc. Appropriate descriptions help the Agent better understand file content and improve the accuracy of subsequent automatic analysis.",
              "  - **Select File Type (fileTypeId)**: Select the correct file type from the dropdown list. **This step is very important** because the system determines which services can process the file based on the file type. Incorrect selection may prevent the use of certain analysis services later.",
              "**Confirm Upload**: Click the \"Upload\" button to start uploading the file."
            ],
            "autoProcessing": {
              "title": "Automatic Processing After Upload:",
              "items": [
                "After successful upload, the system automatically refreshes the project's DAG (Directed Acyclic Graph).",
                "New files immediately appear in the left file list.",
                "File nodes are automatically added to the DAG view, facilitating subsequent viewing of relationships between files and execution steps."
              ]
            },
            "notes": {
              "title": "Notes:",
              "items": [
                "File type selection must be accurate. It is recommended to refer to the \"Service Management\" page to understand the file types supported by each service.",
                "Large file uploads may take some time. Please be patient.",
                "If upload fails, please check if the file format is correct, or contact the administrator."
              ]
            },
            "image": "Upload Data Interface"
          },
          "addContext": {
            "title": "3. Add to Context",
            "description": "Adding key files to context is an important technique to improve Agent analysis quality. By providing relevant files as context, the Agent can more comprehensively understand the project background and task requirements.",
            "whatIsContext": {
              "title": "What is Context?",
              "description": "Context refers to file content that the Agent can access when answering questions and executing tasks. When files are added to context, the Agent automatically reads the file content and references this information when generating analysis plans and explaining results."
            },
            "steps": [
              "**Open Agent Panel**: Ensure a project is selected, and the Agent conversation panel will be displayed on the right.",
              "**Select File**: Find the \"Add to Context\" function in the middle DAG panel (left-click on a file).",
              "**Add File**: Select files from the project file list that need to be added to context, such as:",
              "  - Important result files (such as differential expression analysis results, clustering results, etc.)",
              "  - Configuration files (such as analysis parameter configurations)",
              "  - Key intermediate result files",
              "**Confirm Addition**: After clicking confirm, files will be marked as context files, and the Agent will reference these files in subsequent conversations."
            ],
            "suggestions": {
              "title": "Usage Suggestions:",
              "items": [
                "**Selective Addition**: Do not add all files to context, only select files most relevant to the current analysis task.",
                "**Timely Updates**: When analysis progresses to a new stage, you can remove old context files and add new result files.",
                "**Combine Queries**: After adding context, explicitly mention files that need to be referenced in queries, for example \"Please analyze based on the differential expression result file that has been added to context\"."
              ]
            },
            "tip": "After adding context, the Agent's answers will be more accurate and detailed because it can analyze based on actual file content rather than relying solely on file names and descriptions.",
            "image": "Add to Context Interface"
          },
          "askAgent": {
            "title": "4. Enter User Query to Start Analysis",
            "description": "Through natural language dialogue with the Agent, complex analysis tasks can be automatically completed. This is the core functionality of STA-MAS.",
            "howToUse": {
              "title": "How to Use Agent Dialogue:",
              "steps": [
                "**Enter Query**: In the input box at the bottom of the right Agent panel, describe your needs in natural language, for example:",
                "  - \"Please perform quality control on spatial transcriptomics data, evaluate gene expression and spot quality, and generate a quality control report.\"",
                "  - \"Help me perform differential expression analysis, compare differentially expressed genes between region A and region B, and find the top 20 differentially expressed genes.\"",
                "  - \"Please perform dimensionality reduction and clustering analysis on the data, identify different cell types or spatial regions, and visualize clustering results.\"",
                "  - \"Help me perform pathway enrichment analysis, analyze biological pathways and functions involved in differentially expressed genes.\"",
                "  - \"Identify spatially variable genes in the tumor microenvironment and evaluate the functions of these genes.\"",
                "**Send Query**: Click the \"Send\" button or press Enter to submit the query.",
                "**Wait for Processing**: The Agent will analyze your needs, which may take a few seconds to several minutes. Please be patient."
              ]
            },
            "workflow": {
              "title": "Agent Workflow:",
              "description": "After the Agent receives your query, it will automatically process according to the following steps:",
              "steps": [
                "**Identify Task Requirements**: Understand query intent and analyze tasks that need to be completed",
                "**Develop Task Plan**: Generate task execution plan, listing steps that need to be executed",
                "**Automatically Execute Services**: According to the task plan, call corresponding analysis services to process data",
                "**Generate Execution Results**: After execution completes, generate result files and update DAG",
                "**Retrieve Related Literature** (if needed): For complex biological questions, may retrieve related literature to provide more accurate explanations",
                "**Generate Analysis Report**: Synthesize all information to generate analysis report and conclusions"
              ]
            },
            "images": {
              "sendQuery": "Send Query Message",
              "generatePlans": "Agent Develops Task Plan",
              "invokeService": "Agent Automatically Executes Service",
              "generateFiles": "Agent Generates Result Files",
              "readFiles": "Agent Reads Result Files",
              "retrieveLiterature": "Agent Retrieves and Reads Literature"
            },
            "imageCaptions": {
              "sendQuery": "After clicking send, the Agent starts processing the query.",
              "generatePlans": "The Agent identifies task requirements and develops a task plan, listing steps to be executed and services to be used.",
              "invokeService": "The Agent automatically calls corresponding analysis services according to the task plan.",
              "generateFiles": "After executing the service, the Agent generates result files and updates the project's DAG view.",
              "retrieveLiterature": "For complex biological questions, the Agent retrieves and reads related literature to provide more accurate explanations and suggestions."
            }
          },
          "viewReport": {
            "title": "5. Get Report and Results",
            "description": "After analysis completes, the Agent will output an analysis report in the conversation panel, including:",
            "reportContent": [
              "**Key Findings**: Summarize important results in the analysis, such as differentially expressed genes, significant pathways, etc.",
              "**Biological Interpretation**: Provide biological interpretation of key genes, pathways, etc.",
              "**Research Conclusions**: Synthesize all analysis results to provide overall research conclusions and suggestions"
            ],
            "note": "Reports support Markdown format, including structured content such as tables and lists, making them easy to read and understand.",
            "image": "Agent Generates Conclusion"
          }
        }
      },
      "analysisPage": {
        "title": "Analysis Page",
        "description": "The Analysis page is **the core working area of STA-MAS**, integrating project management, data visualization, execution workflow management, and intelligent dialogue, providing a unified working environment for spatial transcriptomics analysis. Users can either manually execute analysis services or call Agent for automatic analysis, flexibly meeting analysis needs in different scenarios.",
        "overviewImage": "Analysis Page Overview",
        "pageStructure": {
          "title": "Page Structure",
          "description": "The Analysis page uses a classic three-column layout design, consisting of three parts:",
          "parts": [
            "**Left: Project / File Panel** - For project management and file browsing",
            "**Middle: Content Area (DAG or Data Visualization Components)** - Display execution workflow or data analysis results",
            "**Right: Agent Intelligent Dialogue Area** - Interact with intelligent Agent (only displayed after selecting a project)"
          ]
        },
        "leftPanel": {
          "title": "Left Panel",
          "description": "The left panel is the entry point for project and data management, displaying different content based on current state:",
          "projectList": {
            "title": "Project List (when no project is selected)",
            "items": [
              "Display all created projects (`ProjectListPanel`)",
              "Supported functions:",
              "  - **Select Project**: Click project name to select and enter the project",
              "  - **Delete Project**: Right-click project or use delete button (Note: Deleting a project will also delete all files and execution records under the project)",
              "  - **Preview Project DAG**: Can quickly preview the project's execution graph to understand the project's basic structure"
            ]
          },
          "fileList": {
            "title": "File List (after selecting project)",
            "items": [
              "Display all uploaded files under the current project (`FileListPanel`)",
              "Supported operations:",
              "  - **Upload New File**: Click \"Add Data\" or \"Upload File\" button to upload new files",
              "  - **Select File**: Click file name to enter corresponding data analysis page, view file visualization or detailed information",
              "  - **Edit File Information**: Can modify file name, description, and other information",
              "  - **Delete File**: Delete unnecessary files (Note: Deleting files may affect execution records that depend on the file)",
              "  - **View File Details**: View file metadata, creation time, file type, and other information"
            ]
          },
          "features": {
            "title": "Panel Features:",
            "items": [
              "The left panel has an independent collapse button that can collapse the panel to expand the display space of the middle content area",
              "Collapse state is automatically saved in local browser, and will automatically restore the previous state when opened next time",
              "Panel width can be adjusted by dragging the boundary"
            ]
          }
        },
        "middleContent": {
          "title": "Middle Content Area",
          "description": "The middle content area is the core display area of the Analysis page, displaying different views based on user operations:",
          "dagView": {
            "title": "DAG Visualization (Default View)",
            "description": "By default, displays the current project's execution graph (DAG - Directed Acyclic Graph)",
            "elements": {
              "title": "DAG Components:",
              "nodes": "**Nodes (nodes)**: Including execution step nodes and file nodes",
              "nodesDetails": [
                "Execution step nodes: Represent a service call or analysis operation",
                "File nodes: Represent input or output data files"
              ],
              "edges": "**Edges (edges)**: Connect nodes, representing data flow and dependencies between steps",
              "edgesDetails": [
                "Arrow direction represents data flow direction",
                "Edge styles may represent different relationship types"
              ],
              "files": "**Associated File Information (files)**: Each node can associate multiple files, displaying detailed file information"
            },
            "useCases": {
              "title": "Use Cases:",
              "items": [
                "View overall execution workflow, understand the overall architecture of analysis",
                "View dependencies between steps, understand data flow process",
                "Quickly locate a file or execution node, click node to view detailed information",
                "Identify execution failure causes, quickly locate failed steps and their dependencies through DAG"
              ]
            }
          },
          "dataVisualization": {
            "title": "Data Visualization Components",
            "items": [
              "**Switching Mechanism**: When clicking a file in the left file list, the system will:",
              "  - Automatically determine corresponding visualization component based on file name and file type",
              "  - Jump to corresponding data analysis page (such as spatial transcriptomics slice visualization, differential expression gene volcano plot, etc.)",
              "**Return to DAG View**: Click the same file again to return from visualization view to DAG view, facilitating flexible switching between global workflow and local analysis",
              "**Supported Visualization Types**: Automatically select appropriate visualization method based on file type, such as tables, charts, interactive graphics, etc."
            ],
            "image": "File Preview Interface"
          }
        },
        "rightPanel": {
          "title": "Right Agent Panel",
          "description": "The right Agent panel is the core interaction area for intelligent analysis:",
          "displayCondition": "**Display Condition**: Only displayed after selecting a project, ensuring the Agent has sufficient context information",
          "mainFunctions": {
            "title": "Main Functions:",
            "items": [
              "**Intelligent Dialogue**: Natural language dialogue with multi-agent system",
              "**Automatic Analysis**: Automatically generate analysis plans and explanations based on project context and file content",
              "**Advanced Operations**:",
              "  - Add files to context to improve Agent's understanding ability",
              "  - Trigger specific analysis components, automatically switch to corresponding visualization view",
              "  - Automatically refresh DAG, update execution status",
              "  - Generate analysis reports, summarize analysis results"
            ]
          },
          "uiFeatures": {
            "title": "Interface Features:",
            "items": [
              "Right panel width can be adjusted by dragging the boundary to accommodate different dialogue content lengths",
              "Dialogue history is automatically saved, facilitating review of previous analysis processes"
            ]
          }
        },
        "manualExecution": {
          "title": "Manual Service Execution",
          "description": "In addition to using Agent for automatic analysis execution, the system also supports manual service execution, giving users more control. Manual execution is suitable for advanced users with clear planning of analysis workflows, allowing precise control over execution parameters and timing for each service.",
          "stepsTitle": "Operation Steps:",
          "step1": {
            "title": "Open Manual Execution Page",
            "description": "In DAG view or file list, left-click on a file, find the service that needs to be executed, and click the execute button.",
            "image": "Open Manual Execution Page"
          },
          "step2": {
            "title": "Fill Execution Parameters",
            "description": "In the manual execution page, you need to complete the following configuration:",
            "items": [
              "**File ID Auto-filled**: The system automatically fills in the file ID and validates whether the file type matches service requirements",
              "**Set Service Parameters**: Fill in necessary parameters according to service requirements (if any)",
              "**View Service Description**: Can view detailed service description to understand service functions, input/output requirements, etc."
            ],
            "image": "Fill Execution Parameters"
          },
          "step3": {
            "title": "Execute Service",
            "description": "After configuration is complete, click the \"Execute\" button to start executing the service:",
            "items": [
              "During execution, you can view execution logs to understand execution progress in real-time",
              "You can click the \"Exit\" button at any time, and the service will continue executing in the background"
            ],
            "image": "Service Execution Process"
          },
          "step4": {
            "title": "View Results",
            "description": "After execution completes, the system automatically processes the results:",
            "items": [
              "The page automatically refreshes and updates the DAG view",
              "Newly generated result files are automatically added to the file list",
              "You can view newly added execution nodes and file nodes in the DAG"
            ]
          }
        }
      },
      "dataAnalysisPage": {
        "title": "Data Analysis Page",
        "description": "To support more granular data analysis, STA-MAS provides multiple **Data Analysis Pages**. These pages provide specialized visualization and interaction methods for different analysis needs. When you select different files in the file list, the middle content area automatically switches to the corresponding analysis view.",
        "supportedViews": {
          "title": "Supported Analysis Perspectives:",
          "items": [
            "**File Perspective Analysis**: Organized by file dimension, focusing on content interpretation of a single file",
            "**Execution Perspective Analysis**: Organized by execution records, focusing on complete execution workflow and results",
            "**Dedicated Visualization**: Dedicated visualization components for specific data types (such as spatial transcriptomics `SpatialTranscriptomics`, single-cell data, etc.)"
          ]
        },
        "filePerspective": {
          "title": "File Perspective",
          "description": "**File Perspective** is a specialized view for analyzing single file content, suitable for answering the following types of questions:",
          "questions": [
            "\"What information does this file contain?\"",
            "\"How should these results be interpreted?\"",
            "\"Which columns/metrics are most critical?\"",
            "\"What is the relationship between this file and other files?\"",
            "\"Are there any outliers or data points that need attention in the file?\""
          ],
          "supportedFileTypes": {
            "title": "Typical File Types Supported for Interpretation",
            "description": "File perspective can handle multiple types of files:",
            "categories": [
              "**Experimental Result Files**:",
              "  - Spatial transcriptomics matrix files (expression matrix, coordinate information, etc.)",
              "  - Statistical tables (differential expression results, enrichment analysis results, etc.)",
              "  - Annotation files (gene annotations, pathway information, etc.)",
              "**Intermediate Result Files**:",
              "  - Clustering result files (cell types, spatial domains, etc.)",
              "  - Differential analysis results (differential gene lists, statistical values, etc.)",
              "  - Dimensionality reduction results (PCA, UMAP coordinates, etc.)",
              "**Configuration and Log Files**:",
              "  - Configuration files (analysis parameters, service configurations, etc.)",
              "  - Log files (execution logs, error information, etc.)",
              "  - Metadata files (sample information, experimental conditions, etc.)"
            ]
          },
          "steps": {
            "title": "Operation Steps",
            "selectFile": {
              "title": "1. **Select File**",
              "items": [
                "Click target file in the left `FileListPanel`",
                "The system automatically routes to appropriate analysis view based on file type:",
              "  - **Table files**: Display as interactive data tables, supporting sorting, filtering, search, and other operations",
              "  - **Image files**: Directly display image content, supporting zoom and viewing",
              "  - **Text files**: Display text content, supporting syntax highlighting (if code or structured text)",
              "  - **Other types**: Automatically select appropriate display method based on file extension and content"
              ]
            },
            "inputQuery": {
              "title": "2. **Input Query**",
              "description": "In the right Agent panel, ask questions about the file",
              "examples": [
                "\"Please explain what the three most important metrics in this file represent?\"",
                "\"Based on this result file, what is the overall conclusion, and what are the outliers that need attention?\"",
                "\"Which genes or pathways in this file are most worth attention?\"",
                "\"Please help me analyze the statistical characteristics of this file, including data distribution, outliers, etc.\"",
                "\"What is the relationship between this file and other files in the project?\""
              ]
            },
            "viewResults": {
              "title": "3. **View Results**",
              "middleArea": {
                "title": "**Middle Area**: Display visualization or structured information of the file",
                "items": [
                  "Table files: Display as interactive tables, can sort, filter, search",
                  "Data files: Automatically generate appropriate charts (such as distribution charts, correlation charts, etc.)",
                  "Text files: Display text content, supporting code highlighting and formatting"
                ]
              },
              "rightAgent": {
                "title": "**Right Agent**: Use natural language to provide explanations, conclusions, and suggestions",
                "items": [
                  "File content summary: Summarize main content and key information of the file",
                  "Data interpretation: Explain data meaning and biological significance",
                  "Anomaly detection: Identify and explain outliers or data points that need attention",
                  "Association analysis: Analyze relationships between files and other files or execution records",
                  "Support multi-turn questioning: Can continue in-depth questioning based on Agent's answers"
                ]
              }
            }
          },
          "tips": {
            "title": "Usage Tips:",
            "items": [
              "In queries, explicitly specify files that need attention, for example \"Please analyze the currently open file\"",
              "Can combine context files to let Agent perform comprehensive analysis based on multiple files",
              "For large files, can ask Agent to first view file summary, then decide whether detailed analysis is needed"
            ]
          },
          "image": "File Perspective Analysis Interface"
        },
        "executionPerspective": {
          "title": "Execution Perspective",
          "description": "**Execution Perspective** focuses on a complete execution process, providing full workflow analysis capabilities from input to output. This perspective is particularly suitable for understanding complex analysis workflows, troubleshooting execution errors, and comparing results from different executions.",
          "suitableQuestions": {
            "title": "Suitable Question Types:",
            "items": [
              "Evaluate execution quality based on results",
              "What does this execution result indicate, and what new findings are there?",
              "Evaluate data quality based on execution results",
              "Which steps in this execution are most critical?",
              "Are the execution results consistent with expectations?"
            ]
          },
          "supportedContent": {
            "title": "Supported Analysis Content",
            "description": "Execution perspective can analyze the following content:",
            "singleExecution": {
              "title": "**Single Execution Analysis**:",
              "items": [
                "All steps and intermediate files associated with an execution ID",
                "Execution timeline, including start and end time of each step",
                "Execution parameter configuration and input files"
              ]
            }
          },
          "steps": {
            "title": "Operation Steps",
            "selectExecution": {
              "title": "1. **Select Execution Record**",
              "items": [
                "In the left file list or DAG view, find the target execution record",
                "Click the execution node or execution-related file, and the system will automatically switch to the execution perspective"
              ]
            },
            "viewExecutionDetails": {
              "title": "2. **View Execution Details**",
              "middleArea": {
                "title": "**Middle Area**: Display visualization information of the execution",
                "items": [
                  "Execution flowchart: Display complete execution steps and dependencies",
                  "Timeline view: Display execution time of each step",
                  "Input/output files: List all files involved in the execution"
                ]
              },
              "executionInfoPanel": {
                "title": "**Execution Info Panel**: Display execution metadata",
                "items": [
                  "Execution ID, status, start and end time",
                  "Services used and parameter configuration"
                ]
              }
            },
            "interactWithAgent": {
              "title": "3. **Interact with Agent**",
              "description": "In the right Agent panel, ask questions about the execution",
              "examples": {
                "title": "Example Queries:",
                "items": [
                  "\"Please evaluate the quality of this execution, are the results reliable?\"",
                  "\"What important findings did this execution produce?\"",
                  "\"Are there any issues or anomalies that need attention during the execution?\"",
                  "\"What is the relationship between the results of this execution and other executions in the project?\""
                ]
              },
              "agentProvides": {
                "title": "Agent will provide:",
                "items": [
                  "**Execution Quality Assessment**: Analyze execution completeness and result reliability",
                  "**Result Interpretation**: Explain the meaning and biological significance of execution results",
                  "**Problem Diagnosis**: Identify potential issues in the execution process"
                ]
              }
            }
          },
          "image": "Execution Perspective Analysis Interface"
        }
      },
      "serviceManagement": {
        "title": "Service Management",
        "description": "To help users intuitively understand the services supported by the system and the relationships between services and file types, STA-MAS provides **Service Management** functionality. This function helps users understand the system's capability boundaries, plan analysis workflows, and discover available analysis services.",
        "serviceInfo": {
          "title": "Service Information Query",
          "description": "The Service Information Query page provides detailed information about all available services in the system, helping users understand each service's functions, input/output requirements, etc.",
          "functions": {
            "title": "Function Description:",
            "items": [
              "**Service List**: List all analysis services currently supported by the system by service dimension",
              "**Service Details**: Each service displays the following information:",
              "  - **Name and Introduction**: Service name and brief function description",
              "  - **Input File Types**: What types of files the service needs as input",
              "  - **Output File Types**: What types of files the service will generate as output",
              "  - **Service Parameters**: What parameters the service supports, parameter descriptions and default values",
              "  - **Version Information**: Service version number (if any)",
              "  - **Status Information**: Current status of the service (available, maintenance, etc.)"
            ]
          },
          "useCases": {
            "title": "Use Cases:",
            "items": [
              "**Plan Analysis Workflow**: Before uploading new type data, confirm whether there are suitable processing services",
              "**Understand Service Capabilities**: When planning the entire analysis workflow, understand which services can be called at each step",
              "**Parameter Configuration**: View parameters supported by services, prepare for manual service execution",
              "**Service Selection**: Compare functions of different services, select the service most suitable for current needs"
            ]
          },
          "operations": {
            "title": "Operation Methods:",
            "items": [
              "Browse all available services in the service list",
              "Click service name to expand and view detailed information",
              "Use search function to quickly find specific services",
              "Can filter by file type to see which services can process specific types of files"
            ]
          },
          "tip": "The Service Information Query page can help you understand the system's capabilities, but usually you don't need to manually view all services. The Agent will automatically select appropriate services based on your needs.",
          "images": {
            "list": "Service Information Query List",
            "detail": "Service Information Details"
          }
        },
        "relationshipGraph": {
          "title": "Relationship Graph Query",
          "description": "Relationship Graph Query displays services, file types, and their relationships in a visual way, helping users understand how data flows in the system from a global perspective.",
          "functions": {
            "components": {
              "title": "**Relationship Graph Components**:",
              "items": [
                "**Service Nodes**: Represent various analysis services in the system",
                "**File Type Nodes**: Represent various file types supported by the system",
                "**Relationship Edges**: Connect service nodes and file type nodes, representing:",
                "  - **Input Relationship**: Service needs a certain file type as input",
                "  - **Output Relationship**: Service will generate a certain file type as output",
                "  - **Support Relationship**: Service supports processing a certain file type"
              ]
            }
          },
          "interactions": {
            "title": "Interactive Functions:",
            "items": [
              "**Node Click**: After clicking a service node or file type node, highlights:",
              "  - All connections related to the node",
              "  - Related services or file types",
              "  - Data flow paths",
              "**Path Tracking**: Can track complete paths from one file type to another file type",
              "**Dependency Analysis**: View which file types a service depends on, or which services can process a certain file type"
            ]
          },
          "useCases": {
            "title": "Use Cases:",
            "items": [
              "**Workflow Planning**: Understand \"how data flows between services\" from a global perspective, plan complete analysis workflows",
              "**Dependency Analysis**: Understand what prerequisites a service needs, or what subsequent analyses a file type can be used for",
              "**Bottleneck Identification**: Discover potential workflow bottlenecks or service components that need to be supplemented",
              "**Learn System**: For new users, quickly understand the overall architecture and capabilities of the system through relationship graphs"
            ]
          },
          "tips": {
            "title": "Operation Tips:",
            "items": [
              "Click service nodes to see which file types the service can process and which file types it will generate",
              "Click file type nodes to see which services can process the type and which services will generate the type",
              "Use zoom and pan functions to view relationship graph details",
              "Use filter function to only display specific types of nodes or relationships"
            ]
          },
          "tip": "Relationship graphs are good tools for understanding system architecture, but for daily use, you usually don't need to view them frequently. The Agent will automatically handle service selection and workflow planning.",
          "images": {
            "overview": "Relationship Graph Overview",
            "interaction": "Relationship Graph Interaction",
            "path": "Relationship Graph Path Tracking"
          }
        }
      },
      "executionManagement": {
        "title": "Execution Management",
        "description": "The **Execution Management** page is the center for viewing and managing all execution records, providing a complete view of execution history and powerful error troubleshooting functionality. Whether automatic or manual execution, all execution records are uniformly managed here.",
        "functions": {
          "title": "Function Description",
          "executionList": {
            "title": "Execution List View:",
            "items": [
              "**List Display**: Display all execution records in table form, including:",
              "  - **Execution ID**: Unique identifier for each execution",
              "  - **Execution Name**: Name or description of the execution",
              "  - **Associated Project**: Project to which the execution belongs",
              "  - **Execution Status**: Success, failure, running, waiting, etc.",
              "  - **Start and End Time**: Start time and end time of the execution",
              "  - **Execution Duration**: Total time spent on execution",
              "  - **Services Used**: Service names called by the execution",
              "**Filter Function**: Support filtering execution records by multiple dimensions:",
              "  - **Filter by Project**: Only display execution records for specific projects",
              "  - **Filter by Time**: Filter by time range, such as last day, week, month, etc.",
              "  - **Filter by Status**: Only display executions with specific status (such as only failed executions)",
              "  - **Filter by Service**: Only display executions using specific services",
              "  - **Combined Filter**: Can use multiple filter conditions simultaneously"
            ]
          },
          "executionDetails": {
            "title": "Execution Details View:",
            "items": [
              "Click execution record to view detailed information:",
              "  - **Execution Parameters**: All parameters used during execution",
              "  - **Input Files**: List of input files used by the execution",
              "  - **Output Files**: All output files generated by the execution",
              "  - **Execution Logs**: Complete execution logs, including output of each step",
              "  - **Execution Path**: Highlight the execution's path in the DAG"
            ]
          },
          "images": {
            "list": "Execution Management List",
            "detail": "Execution Management Details"
          }
        },
        "errorTroubleshooting": {
          "title": "Error Troubleshooting",
          "description": "The Execution Management page provides powerful error troubleshooting functionality to help users quickly locate and resolve execution issues.",
          "errorDisplay": {
            "title": "Error Information Display:",
            "items": [
              "**Error Status Identification**: Failed executions are marked with red or other prominent colors",
              "**Error Summary**: Display brief error information in the list",
              "**Detailed Error Logs**: Click failed execution to view:",
              "  - **Error Message**: Error message or exception information provided by the system",
              "  - **Error Stack**: Complete error stack information (if any)",
              "  - **Execution Logs**: All log output during execution, helping locate where the error occurred",
              "  - **Related Files**: Input/output files related to the error"
            ]
          },
          "errorDiagnosis": {
            "title": "Error Diagnosis Assistance:",
            "items": [
              "**Agent Error Analysis**: For failed executions, can ask in the Agent panel:",
              "  - \"Please analyze the reason for this execution failure\"",
              "  - \"Based on the error logs, what are the repair suggestions?\"",
              "  - \"How to avoid similar errors?\"",
              "**Error Pattern Recognition**: The system may identify common error patterns and provide targeted solutions",
              "**Related Execution Comparison**: Can compare failed execution with successful execution to find differences"
            ]
          },
          "suggestions": {
            "title": "Usage Suggestions:",
            "items": [
              "**Regular Check**: Regularly view the Execution Management page to promptly discover and handle failed executions",
              "**Error Analysis**: For failed executions, don't immediately retry, first analyze the error cause",
              "**Log Viewing**: Carefully view execution logs, usually can find the root cause of the error",
              "**Seek Help**: If unable to resolve, can ask Agent for diagnostic suggestions or contact technical support"
            ]
          },
          "tip": "The Execution Management page is an important tool for maintaining analysis workflow health. It is recommended to regularly view it, promptly handle failed executions, and ensure smooth progress of analysis workflows."
        }
      }
    }
  },
